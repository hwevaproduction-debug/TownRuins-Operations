{
  "name": "traycer_send_message",
  "description": "Send a message to another Traycer agent in this epic.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "toAgentId": {
        "type": "string",
        "description": "Target Traycer agent id."
      },
      "message": {
        "type": "string",
        "description": "Message to deliver."
      },
      "expectReply": {
        "type": [
          "boolean",
          "null"
        ],
        "description": "Whether the receiver should reply."
      },
      "responseId": {
        "type": [
          "string",
          "null"
        ],
        "description": "Broker response id when replying to a pending request."
      }
    },
    "required": [
      "toAgentId",
      "message"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}